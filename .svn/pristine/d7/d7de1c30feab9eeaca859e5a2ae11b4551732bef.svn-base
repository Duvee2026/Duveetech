        <script>
            // keep your initial scroll trigger if needed
            // optional: trigger a scroll event after load like you had
            setTimeout(function () { $(window).scroll(); }, 50);

            $("body").on("click", ".scroll-to-services", function (e) {
                e.preventDefault();
                var $target = $("#services");
                if (!$target.length) return;

                // adjust if you have a fixed header (set to 0 if no fixed header)
                var headerOffset = 100;
                var top = Math.max(0, $target.offset().top - headerOffset);

                // respect reduced motion preference
                if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                    $("html, body").scrollTop(top);
                } else {
                    $("html, body").stop().animate({ scrollTop: top }, 600, 'swing');
                }
            });

        </script>

        <script>
            const popup = document.getElementById("popup");
            const video = document.getElementById("myVideo");
            const playBtn = document.getElementById("playBtn");
            const closeBtn = document.getElementById("closeBtn");

            // Open popup on button click
            playBtn.addEventListener("click", function (e) {
                e.preventDefault(); // Prevent page jump
                popup.style.display = "flex";
                video.currentTime = 0; // Start from beginning
                video.play();
            });

            // Close popup on close button
            closeBtn.addEventListener("click", function () {
                popup.style.display = "none";
                video.pause();
            });

            // (Optional) Close popup when clicking outside the video box
            window.addEventListener("click", function (e) {
                if (e.target === popup) {
                    popup.style.display = "none";
                    video.pause();
                }
            });

        </script>

