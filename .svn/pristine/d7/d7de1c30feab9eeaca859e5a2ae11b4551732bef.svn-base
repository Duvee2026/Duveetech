    <script>
function triggerLead(formName, hiddenId) {
  var eid = formName + '_' + Date.now() + '_' + Math.random().toString(36).substr(2,5);
  document.getElementById(hiddenId).value = eid;
  fbq('track', 'Lead', {
    content_name: formName,
    value: 1.00,
    currency: 'INR'
  }, {
    eventID: eid
  });
}
</script>
