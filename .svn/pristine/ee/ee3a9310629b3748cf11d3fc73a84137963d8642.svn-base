<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thank You</title>
    <link rel="stylesheet" href="../HTWF/style.css">
    <style>
        body {
            text-align: center;
            padding: 80px 20px;
            font-family: Arial, sans-serif;
            background: #f8f8f8;
        }

        .thankyou-box {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
            display: inline-block;
            padding: 40px 60px;
        }

        h1 {
            color: #4A90E2;
            margin-bottom: 20px;
        }

        p {
            color: #333;
            font-size: 18px;
        }

        a {
            color: #4A90E2;
            text-decoration: underline;
        }
    </style>

    <script>(function (w, d, s, l, i) {
            w[l] = w[l] || []; w[l].push({
                'gtm.start':
                    new Date().getTime(), event: 'gtm.js'
            }); var f = d.getElementsByTagName(s)[0],
                j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
                    'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
        })(window, document, 'script', 'dataLayer', 'GTM-MKTMCWL5');
    </script>

</head>

<body>

    <!-- Google Tag Manager -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MKTMCWL5" height="0" width="0"
            style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <div class="thankyou-box">
        <h1>Thank You!</h1>
        <p>Your message has been sent successfully.<br>We appreciate your interest and will get back to you soon.</p>
        <p><a href="index.html">Return to Home</a></p>
    </div>
</body>

</html>