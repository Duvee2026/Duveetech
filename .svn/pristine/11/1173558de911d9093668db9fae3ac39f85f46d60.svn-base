        <div class="form-box" style="max-width: 900px; margin: 80px auto 0 auto;">
            <h1 class="font-weight-300" style="margin-bottom: 30px;">Get in touch</h1>
            <form id="contactForm" action="send_mail.php" method="POST">
                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px;">
                    <div style="display: flex; flex-direction: column;">
                        <input type="text" name="name" placeholder="Name" class="form-control" required minlength="2"
                            maxlength="50" pattern="[A-Za-z\s]+"
                            style="border-radius: 25px; border: 2px solid #4A90E2; color: #000;"
                            oninvalid="this.setCustomValidity('Please enter your name (letters only, min 2 characters).')"
                            oninput="this.setCustomValidity('')" />
                        <span class="error-message" style="color: red; font-size: 13px; min-height: 18px;"></span>
                    </div>
                    <div style="display: flex; flex-direction: column;">
                        <input type="email" name="email" placeholder="Email" class="form-control" required
                            style="border-radius: 25px; border: 2px solid #4A90E2; color: #000;"
                            oninvalid="this.setCustomValidity('Please enter a valid email address.')"
                            oninput="this.setCustomValidity('')" />
                        <span class="error-message" style="color: red; font-size: 13px; min-height: 18px;"></span>
                    </div>
                    <div style="display: flex; flex-direction: column;">
                        <input type="tel" name="mobile" placeholder="Mobile Number" class="form-control" required
                            pattern="[0-9]{10}" maxlength="10"
                            style="border-radius: 25px; border: 2px solid #4A90E2; color: #000;"
                            oninvalid="this.setCustomValidity('Please enter a valid 10-digit mobile number.')"
                            oninput="this.setCustomValidity('')"
                            onkeypress="if(event.which<48||event.which>57||this.value.length>=10)event.preventDefault();" />
                        <span class="error-message" style="color: red; font-size: 13px; min-height: 18px;"></span>
                    </div>
                    <div style="grid-column: span 2; display: flex; flex-direction: column;">
                        <textarea name="message" placeholder="Message" class="form-control" rows="4"
                            style="border-radius: 25px; border: 2px solid #4A90E2; resize: none; padding: 10px 15px; color: #000;"></textarea>
                        <span class="error-message" style="color: red; font-size: 13px; min-height: 18px;"></span>
                    </div>
                    <button type="submit" class="btn btn-lg"
                        style="align-self: center; justify-self: center; background: linear-gradient(90deg, #4A90E2 0%, #0072ff 100%); color: #fff; border: none; border-radius: 25px; padding: 12px 40px; font-size: 18px; font-weight: 600; box-shadow: 0 4px 16px rgba(74,144,226,0.15); transition: background 0.3s, box-shadow 0.3s;">Submit</button>
                </div>
            </form>
            <script>
                document.getElementById('contactForm').addEventListener('submit', function (e) {
                    let valid = true;
                    const form = this;
                    // Name validation
                    const name = form.elements['name'];
                    const nameError = name.parentElement.querySelector('.error-message');
                    if (!name.value.trim()) {
                        nameError.textContent = 'Name is required.';
                        valid = false;
                    } else if (!/^[A-Za-z\s]{2,50}$/.test(name.value.trim())) {
                        nameError.textContent = 'Please enter your name (letters only, min 2 characters).';
                        valid = false;
                    } else {
                        nameError.textContent = '';
                    }
                    // Email validation
                    const email = form.elements['email'];
                    const emailError = email.parentElement.querySelector('.error-message');
                    if (!email.value.trim()) {
                        emailError.textContent = 'Email is required.';
                        valid = false;
                    } else if (!/^\S+@\S+\.\S+$/.test(email.value.trim())) {
                        emailError.textContent = 'Please enter a valid email address.';
                        valid = false;
                    } else {
                        emailError.textContent = '';
                    }
                    // Mobile validation
                    const mobile = form.elements['mobile'];
                    const mobileError = mobile.parentElement.querySelector('.error-message');
                    if (!mobile.value.trim()) {
                        mobileError.textContent = 'Mobile number is required.';
                        valid = false;
                    } else if (!/^[0-9]{10}$/.test(mobile.value.trim())) {
                        mobileError.textContent = 'Please enter a valid 10-digit mobile number.';
                        valid = false;
                    } else {
                        mobileError.textContent = '';
                    }
                    // Message field is optional, clear error
                    const message = form.elements['message'];
                    const messageError = message.parentElement.querySelector('.error-message');
                    messageError.textContent = '';
                    if (!valid) e.preventDefault();
                });
            </script>

