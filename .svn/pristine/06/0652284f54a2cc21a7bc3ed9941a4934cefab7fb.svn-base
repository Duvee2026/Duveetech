<?php
// Basic security: only allow POST
if ($_SERVER["REQUEST_METHOD"] === "POST") {
	// Sanitize and validate input
	$name = htmlspecialchars(trim($_POST['name'] ?? ''));
	$email = htmlspecialchars(trim($_POST['email'] ?? ''));
	$mobile = htmlspecialchars(trim($_POST['mobile'] ?? ''));
	$message = htmlspecialchars(trim($_POST['message'] ?? ''));

	// Validate required fields
	if (!$name || !$email || !$mobile) {
		echo "<script>alert('Please fill in all required fields.'); window.history.back();</script>";
		exit();
	}

	// Validate email
	if (!filter_var($email, FILTER_VALIDATE_EMAIL)) {
		echo "<script>alert('Invalid email address.'); window.history.back();</script>";
		exit();
	}

	// Validate mobile (10-15 digits)
	if (!preg_match('/^[0-9]{10,15}$/', $mobile)) {
		echo "<script>alert('Invalid mobile number.'); window.history.back();</script>";
		exit();
	}

	$to = "david.a.25897@gmail.com"; // Change to your email address
	$subject = "New Contact Form Submission";
	$body = "You have received a new message from the contact form.\n\n" .
			"Name: $name\n" .
			"Email: $email\n" .
			"Mobile: $mobile\n" .
			"Message: $message\n";
	$headers = "From: noreply@" . $_SERVER['SERVER_NAME'] . "\r\n" .
			   "Reply-To: $email\r\n";

	// if (mail($to, $subject, $body, $headers)) {
	//     header('Location: thankyou.html');
	//     exit();
	// } else {
	//     echo "<script>alert('Sorry, your message could not be sent. Please try again later.'); window.history.back();</script>";
	// }
} else {
	// Redirect to home if accessed directly
