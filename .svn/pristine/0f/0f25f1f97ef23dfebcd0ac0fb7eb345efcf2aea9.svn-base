        <script>
            // keep your initial scroll trigger if needed
            // optional: trigger a scroll event after load like you had
            setTimeout(function () { $(window).scroll(); }, 50);

            $("body").on("click", ".scroll-to-services", function (e) {
                e.preventDefault();
                var $target = $("#services");
                if (!$target.length) return;

                // adjust if you have a fixed header (set to 0 if no fixed header)
                var headerOffset = 100;
                var top = Math.max(0, $target.offset().top - headerOffset);

                // respect reduced motion preference
                if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                    $("html, body").scrollTop(top);
                } else {
                    $("html, body").stop().animate({ scrollTop: top }, 600, 'swing');
                }
            });

        </script>

        <script>
            // Math CAPTCHA functionality
            let captchaNum1, captchaNum2, captchaCorrectAnswer;

            function generateCaptcha() {
                captchaNum1 = Math.floor(Math.random() * 10) + 1;
                captchaNum2 = Math.floor(Math.random() * 10) + 1;
                captchaCorrectAnswer = captchaNum1 + captchaNum2;
                document.getElementById('captchaQuestion').textContent = `${captchaNum1} + ${captchaNum2} =`;
            }

            // Generate CAPTCHA on page load
            window.addEventListener('load', generateCaptcha);

            // Validate CAPTCHA on form submission
            document.addEventListener('DOMContentLoaded', function () {
                const form = document.getElementById('contactForm');
                if (form) {
                    form.addEventListener('submit', function (e) {
                        const userAnswer = parseInt(document.getElementById('captchaAnswer').value);
                        const captchaError = document.getElementById('captchaError');

                        if (userAnswer !== captchaCorrectAnswer) {
                            e.preventDefault();
                            captchaError.style.display = 'block';
                            generateCaptcha(); // Generate new question
                            document.getElementById('captchaAnswer').value = '';
                            return false;
                        } else {
                            captchaError.style.display = 'none';
                        }
                    });
                }
            });
        </script>

        </script>

        <script>
            document.getElementById('contactForm').addEventListener('submit', function (e) {
                let valid = true;
                const form = this;
                const errorMessages = form.querySelectorAll('.error-message');
                errorMessages.forEach(err => err.textContent = '');

                // Name validation
                const name = form.elements['name'];
                const nameError = name.parentElement.querySelector('.error-message');
                if (!name.value.trim()) {
                    nameError.textContent = 'Name is required.';
                    valid = false;
                } else if (!/^[A-Za-z\s]{2,100}$/.test(name.value.trim())) {
                    nameError.textContent = 'Please enter a valid name (letters only).';
                    valid = false;
                }

                // Email validation
                const email = form.elements['email'];
                const emailError = email.closest('div').parentElement.querySelector('.error-message');
                if (!email.value.trim()) {
                    emailError.textContent = 'Email is required.';
                    valid = false;
                } else if (!/^\S+@\S+\.\S+$/.test(email.value.trim())) {
                    emailError.textContent = 'Please enter a valid email address.';
                    valid = false;
                }

                // Mobile validation
                const mobile = form.elements['mobile'];
                const mobileError = mobile.closest('div').parentElement.querySelector('.error-message');
                if (!mobile.value.trim()) {
                    mobileError.textContent = 'Mobile number is required.';
                    valid = false;
                } else if (!/^[0-9]{10}$/.test(mobile.value.trim())) {
                    mobileError.textContent = 'Please enter a valid 10-digit mobile number.';
                    valid = false;
                }

                // Message validation (optional - just clear error)
                const message = form.elements['message'];
                const messageError = message.parentElement.querySelector('.error-message');
                messageError.textContent = '';

                if (!valid) e.preventDefault();
            });
        </script>

    </footer>

