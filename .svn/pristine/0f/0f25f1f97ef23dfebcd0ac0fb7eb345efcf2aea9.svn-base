                <!-- Right Side - Contact Form -->
                <div class="col-md-5" style="padding: 40px;">
                    <div class="form-box"
                        style="background: #ffffff; padding: 14px 18px; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
                        <div class="get-in-touch-btn-wrapper">
                            <div class="get-in-touch-banner">Get in Touch</div>
                        </div>
                        <form id="contactForm" action="send_mail.php" method="POST">
                            <div style="display: flex; flex-direction: column; gap: 4px;">
                                <!-- Name Field -->
                                <div style="display: flex; flex-direction: column; align-items: center;">
                                    <label
                                        style="display: block; margin-bottom: 2px; font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: 0.5px; text-align: left; width: 85%;">YOUR
                                        NAME <span style="color: #e74c3c;">*</span></label>
                                    <input type="text" name="name" required minlength="2" maxlength="100"
                                        pattern="[A-Za-z\s]+"
                                        style="width: 85%; padding: 8px 12px; border: 1px solid #e0e0e0; border-radius: 4px; font-size: 14px; color: #333; background: #f9f9f9; transition: border 0.3s;"
                                        oninvalid="this.setCustomValidity('Please enter your full name.')"
                                        oninput="this.setCustomValidity('')"
                                        onfocus="this.style.borderColor='#4A90E2'; this.style.background='#fff';"
                                        onblur="this.style.borderColor='#e0e0e0'; this.style.background='#f9f9f9';" />
                                    <span class="error-message"
                                        style="color: #e74c3c; font-size: 10px; display: block;"></span>
                                </div>

                                <!-- Email Field -->
                                <div style="display: flex; flex-direction: column; align-items: center;">
                                    <label
                                        style="display: block; margin-bottom: 2px; font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: 0.5px; text-align: left; width: 85%;">EMAIL
                                        ADDRESS <span style="color: #e74c3c;">*</span></label>
                                    <div style="position: relative; width: 85%;">
                                        <span
                                            style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #999;">
                                            <i class="fa fa-envelope-o" style="font-size: 14px;"></i>
                                        </span>
                                        <input type="email" name="email" required
                                            style="width: 100%; padding: 8px 12px 8px 36px; border: 1px solid #e0e0e0; border-radius: 4px; font-size: 14px; color: #333; background: #f9f9f9; transition: border 0.3s;"
                                            oninvalid="this.setCustomValidity('Please enter a valid email address.')"
                                            oninput="this.setCustomValidity('')"
                                            onfocus="this.style.borderColor='#4A90E2'; this.style.background='#fff';"
                                            onblur="this.style.borderColor='#e0e0e0'; this.style.background='#f9f9f9';" />
                                    </div>
                                    <span class="error-message"
                                        style="color: #e74c3c; font-size: 10px; display: block;"></span>
                                </div>

                                <!-- Phone Field -->
                                <div style="display: flex; flex-direction: column; align-items: center;">
                                    <label
                                        style="display: block; margin-bottom: 2px; font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: 0.5px; text-align: left; width: 85%;">PHONE
                                        NUMBER <span style="color: #e74c3c;">*</span></label>
                                    <div style="position: relative; width: 85%;">
                                        <span
                                            style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #999;">
                                            <i class="fa fa-phone" style="font-size: 14px;"></i>
                                        </span>
                                        <input type="tel" name="mobile" required pattern="[0-9]{10}" maxlength="10"
                                            style="width: 100%; padding: 8px 12px 8px 36px; border: 1px solid #e0e0e0; border-radius: 4px; font-size: 14px; color: #333; background: #f9f9f9; transition: border 0.3s;"
                                            oninvalid="this.setCustomValidity('Please enter a valid 10-digit mobile number.')"
                                            oninput="this.setCustomValidity('')"
                                            onkeypress="if(event.which<48||event.which>57||this.value.length>=10)event.preventDefault();"
                                            onfocus="this.style.borderColor='#4A90E2'; this.style.background='#fff';"
                                            onblur="this.style.borderColor='#e0e0e0'; this.style.background='#f9f9f9';" />
                                    </div>
                                    <span class="error-message"
                                        style="color: #e74c3c; font-size: 10px; display: block;"></span>
                                </div>

                                <!-- Message Field -->
                                <div style="display: flex; flex-direction: column; align-items: center;">
                                    <label
                                        style="display: block; margin-bottom: 2px; font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: 0.5px; text-align: left; width: 85%;">MESSAGE</label>
                                    <textarea name="message" rows="2"
                                        style="width: 85%; padding: 8px 12px; border: 1px solid #e0e0e0; border-radius: 4px; font-size: 14px; color: #333; background: #f9f9f9; resize: none; transition: border 0.3s; font-family: inherit;"
                                        onfocus="this.style.borderColor='#4A90E2'; this.style.background='#fff';"
                                        onblur="this.style.borderColor='#e0e0e0'; this.style.background='#f9f9f9';"></textarea>
                                    <span class="error-message"
                                        style="color: #e74c3c; font-size: 10px; display: block;"></span>
                                </div>

                                <!-- Custom Math CAPTCHA -->
                                <div
                                    style="margin-top: 8px; display: flex; flex-direction: column; align-items: center;">
                                    <label
                                        style="display: block; margin-bottom: 2px; font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: 0.5px; text-align: left; width: 85%;">SECURITY
                                        CHECK <span style="color: #e74c3c;">*</span></label>
                                    <div
                                        style="display: flex; align-items: center; flex-wrap: wrap; gap: 10px; width: 85%;">
                                        <span id="captchaQuestion"
                                            style="font-size: 16px; font-weight: 600; color: #333; background: #f0f0f0; padding: 10px 18px; border-radius: 4px;"></span>
                                        <input type="number" id="captchaAnswer" required
                                            style="width: 70px; padding: 8px 12px; border: 1px solid #e0e0e0; border-radius: 4px; font-size: 14px; color: #333; background: #f9f9f9; transition: border 0.3s;"
                                            onfocus="this.style.borderColor='#4A90E2'; this.style.background='#fff';"
                                            onblur="this.style.borderColor='#e0e0e0'; this.style.background='#f9f9f9';" />
                                        <div class="submit-enquiry-btn-wrapper">
                                            <button type="submit" class="submit-enquiry-banner">
                                                Submit your Enquiry
                                            </button>
                                        </div>
                                    </div>
                                    <span id="captchaError"
                                        style="color: #e74c3c; font-size: 10px; display: none;">Incorrect answer. Please
                                        try again.</span>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

